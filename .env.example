# Copy this file to `.env` and fill in real values.
# NEVER commit real secrets or a real allowlist email (see SPEC.md §11.6).

# Postgres connection. For local dev this matches docker-compose.yml (host port 5887).
DATABASE_URL="postgresql://bayana:bayana@localhost:5887/bayana?schema=public"

# Dev/seed only: pins the seeded user's id for `scripts/seed-user.ts` (stable reruns).
# NOT used by the running app — auth resolves the user from the session — and NOT needed
# in production.
DEFAULT_USER_ID=

# Anthropic API key for Claude Haiku sentence generation (server-only).
ANTHROPIC_API_KEY=

# Resend API key for magic-link auth emails (Phase 1b).
RESEND_API_KEY=

# Auth.js session secret (Phase 1b). Generate with: openssl rand -base64 32
AUTH_SECRET=

# Magic-link "from" address. Default is Resend's test sender (only delivers to your
# Resend account email). For real use, verify a domain and set e.g. no-reply@yourdomain.
AUTH_EMAIL_FROM=onboarding@resend.dev

# The single email allowed to sign in (Phase 1b). Placeholder only — never a real address.
AUTH_ALLOWED_EMAIL=you@example.com

# Public base URL for Auth.js callback links. Optional locally (trustHost infers
# http://localhost:3887); REQUIRED in production — set to your deployed origin,
# e.g. https://bayana-production.up.railway.app
AUTH_URL=

